# Cashu Mint — example environment configuration
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=3338
DEBUG=false

# Mint identity
MINT_NAME="My Cashu Mint"
MINT_DESCRIPTION="A Cashu ecash mint"
MINT_DESCRIPTION_LONG=""
MINT_MOTD=""
MINT_URL="http://localhost:3338"

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./cashu_mint.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cashu_mint

# Cryptography — set a strong random value; generated automatically if empty
# MINT_PRIVATE_KEY=your-hex-private-key-here

# Lightning backend: fake | lnd | cln | lnbits
LIGHTNING_BACKEND=fake

# LND settings (if LIGHTNING_BACKEND=lnd)
# LND_GRPC_HOST=localhost:10009
# LND_TLS_CERT_PATH=/path/to/tls.cert
# LND_MACAROON_PATH=/path/to/admin.macaroon

# CLN settings (if LIGHTNING_BACKEND=cln)
# CLN_GRPC_HOST=localhost:9736
# CLN_CA_CERT_PATH=/path/to/ca.pem
# CLN_CLIENT_CERT_PATH=/path/to/client.pem
# CLN_CLIENT_KEY_PATH=/path/to/client-key.pem

# LNbits settings (if LIGHTNING_BACKEND=lnbits)
# LNBITS_URL=https://your-lnbits-instance.com
# LNBITS_API_KEY=your-api-key

# Limits
MAX_MINT_AMOUNT=1000000
MAX_MELT_AMOUNT=1000000
MAX_BALANCE=0

# Quote expiry (seconds)
MINT_QUOTE_TTL=3600
MELT_QUOTE_TTL=3600

# Fees
FEE_PERCENT=0.0
FEE_MIN=0
